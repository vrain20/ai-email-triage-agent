      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.item.json;\n\n// Get the text from Gemini response\nconst raw = response.text || \n            response.output || \n            response.response ||\n            response.content ||\n            JSON.stringify(response);\n\n// Clean and parse JSON\nconst cleaned = raw.replace(/```json|```/g, '').trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = {\n    category: \"FYI\",\n    reason: \"Could not parse response\",\n    suggested_reply: \"\"\n  };\n}\n\nreturn [{ \n  json: {\n    ...parsed,\n    emailId: $('Code in JavaScript').item.json.id,\n    threadId: $('Code in JavaScript').item.json.threadId,\n    sender: $('Code in JavaScript').item.json.sender,\n    subject: $('Code in JavaScript').item.json.subject\n  }\n}];"
      },
