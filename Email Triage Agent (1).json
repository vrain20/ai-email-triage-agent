        "jsCode": "return [{\n  json: {\n    id: $input.item.json.id,\n    threadId: $input.item.json.threadId,\n    sender: $input.item.json.from,\n    subject: $input.item.json.subject,\n    body: $input.item.json.text || $input.item.json.snippet || \"\"\n  }\n}];"
